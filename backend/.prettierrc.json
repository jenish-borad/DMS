{

    "semi": true,
    "singleQuote": false,
    "jsxSingleQuote": false,

    "tabWidth": 4,
    "useTabs": false,

    "printWidth": 100,

    "trailingComma": "all",

    "bracketSpacing": true,
    "bracketSameLine": false,

    "arrowParens": "always",

    "quoteProps": "as-needed",

    "endOfLine": "lf",

    "embeddedLanguageFormatting": "auto",

    "proseWrap": "preserve"
}
